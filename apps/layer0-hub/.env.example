# Authority API (required when not in stub mode)
VITE_ANTIPHON_API_URL=http://localhost:8787

# Optional: stub engine (no authority)
# VITE_ANTIPHON_ENGINE_MODE=stub

# Firebase Auth (optional; when set, Hub shows Google / Apple / Email+password sign-in)
# Get these from Firebase Console → Project settings → Your apps. Do not commit real values.
# VITE_FIREBASE_API_KEY=your-api-key
# VITE_FIREBASE_AUTH_DOMAIN=antiphon-sso.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=antiphon-sso
# VITE_FIREBASE_STORAGE_BUCKET=antiphon-sso.firebasestorage.app
# VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
# VITE_FIREBASE_APP_ID=your-app-id
# VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Or a single JSON config (all Firebase web config keys):
# VITE_FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...","storageBucket":"...","messagingSenderId":"...","appId":"...","measurementId":"..."}
